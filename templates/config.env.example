# Path to the original Codex CLI binary. Do not point this at codex_smart.
CODEX_BIN="$HOME/.local/bin/codex"

# Original Codex state directory.
CODEX_ORIGINAL_HOME="$HOME/.codex"

# Ordered rotation of account ids and profile directories. Paths may not contain spaces.
CODEX_ACCOUNTS="1:$HOME/.codex-1 2:$HOME/.codex-2 3:$HOME/.codex-3"

# Runtime state and lock. The default lock is unique per Linux user.
CODEX_ACTIVE_FILE="${XDG_STATE_HOME:-$HOME/.local/state}/codex-profile-manager/active"
CODEX_LOCK_FILE="${XDG_RUNTIME_DIR:-/tmp}/codex-profile-manager-${UID}.lock"

# Choose a filesystem with enough free space for a full backup of CODEX_ORIGINAL_HOME.
CODEX_BACKUP_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/codex-profile-manager/backups"

# Ask whether to rotate after Codex exits.
CODEX_PROMPT_AFTER_EXIT="1"

# Public-safe allowlist. Unknown future Codex files are not shared automatically.
CODEX_SHARED_ITEMS="config.toml sessions history.jsonl session_index.jsonl memories attachments skills rules prompts archived_sessions state_*.sqlite state_*.sqlite-*"
