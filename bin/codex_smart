#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CODEXPM="$SCRIPT_DIR/codexpm"

case "${1:-}" in
  status|list|doctor|migrate|config-path|version|--version|-V|next|use|add|login|logout)
    exec "$CODEXPM" "$@"
    ;;
  switch)
    shift || true
    if [ "$#" -eq 0 ]; then
      exec "$CODEXPM" next
    fi
    exec "$CODEXPM" use "$1"
    ;;
  *)
    exec "$CODEXPM" run "$@"
    ;;
esac
