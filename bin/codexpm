#!/usr/bin/env bash
set -euo pipefail

resolve_self() {
  local source="${BASH_SOURCE[0]}"
  while [ -L "$source" ]; do
    local dir
    dir="$(cd -P "$(dirname "$source")" >/dev/null 2>&1 && pwd)"
    source="$(readlink "$source")"
    [[ "$source" != /* ]] && source="$dir/$source"
  done
  cd -P "$(dirname "$source")" >/dev/null 2>&1 && pwd
}

BIN_DIR="$(resolve_self)"
LIB_DIR="${CODEXPM_LIB_DIR:-$BIN_DIR/../lib}"

# shellcheck source=../lib/config.sh
source "$LIB_DIR/config.sh"
# shellcheck source=../lib/profiles.sh
source "$LIB_DIR/profiles.sh"

codexpm_load_config
codexpm_validate_config

usage() {
  cat <<'EOF_USAGE'
codex-profile-manager (codexpm)

Usage:
  codexpm list
  codexpm status
  codexpm use <profile>
  codexpm next
  codexpm add <profile> [profile_dir]
  codexpm remove <profile> [--delete-files] [--yes]
  codexpm login <profile>
  codexpm logout <profile>
  codexpm run [new|all|resume|-- <codex args...>]
  codexpm doctor
  codexpm migrate
  codexpm uninstall [--purge] [--yes]
  codexpm config-path
  codexpm version

Examples:
  codexpm use work
  codexpm next
  codexpm add backup
  codexpm login backup
  codexpm remove backup
  codexpm remove backup --delete-files
  codexpm run
  codexpm run new
  codexpm uninstall --purge
EOF_USAGE
}

require_codex() {
  [ -x "$CODEX_BIN" ] || {
    echo "Codex binary is not executable: $CODEX_BIN" >&2
    exit 1
  }
}

show_list() {
  local active id path marker auth
  active="$(codexpm_read_active)"
  printf 'Active profile: %s\n\n' "$active"
  while IFS= read -r id; do
    path="$(codexpm_account_path "$id")"
    marker=" "
    [ "$id" != "$active" ] || marker="*"
    auth="not logged in"
    [ ! -f "$path/auth.json" ] || auth="auth present"
    printf '%s %-16s %s (%s)\n' "$marker" "$id" "$path" "$auth"
  done < <(codexpm_account_ids)
}

show_status() {
  local active id path marker
  require_codex
  active="$(codexpm_read_active)"
  printf 'Active profile: %s\n\n' "$active"
  while IFS= read -r id; do
    path="$(codexpm_account_path "$id")"
    marker=""
    [ "$id" != "$active" ] || marker=" [active]"
    printf 'Profile %s%s\n' "$id" "$marker"
    printf 'CODEX_HOME=%s\n' "$path"
    CODEX_HOME="$path" "$CODEX_BIN" login status || true
    echo
  done < <(codexpm_account_ids)
}

run_codex_once() {
  local account="$1" home status
  shift
  home="$(codexpm_account_path "$account")"

  [ -d "$home" ] || {
    echo "Profile directory does not exist: $home" >&2
    return 1
  }

  mkdir -p "$(dirname "$CODEX_LOCK_FILE")"
  exec 9>"$CODEX_LOCK_FILE"
  if ! flock -n 9; then
    echo "Another managed Codex session is already using the shared state." >&2
    exec 9>&-
    return 75
  fi

  echo "Using Codex profile: $account"
  set +e
  CODEX_HOME="$home" "$CODEX_BIN" "$@"
  status=$?
  set -e

  flock -u 9 || true
  exec 9>&-
  return "$status"
}

run_codex() {
  local active status next answer
  active="$(codexpm_read_active)"
  require_codex

  set +e
  run_codex_once "$active" "$@"
  status=$?
  set -e

  if [ "$status" -ne 0 ]; then
    return "$status"
  fi

  if [ "$CODEX_PROMPT_AFTER_EXIT" != "1" ] || [ ! -t 0 ]; then
    return 0
  fi

  next="$(codexpm_next_account "$active")"
  [ "$next" != "$active" ] || return 0
  echo
  read -r -p "Switch to profile $next and resume? [y/N] " answer
  case "$answer" in
    y|Y|yes|YES)
      codexpm_set_active "$next"
      echo "Switched Codex profile: $active -> $next"
      run_codex_once "$next" resume --last
      ;;
    *)
      echo "Keeping active Codex profile: $active"
      return 0
      ;;
  esac
}

run_command() {
  case "${1:-resume}" in
    new)
      shift || true
      run_codex "$@"
      ;;
    all)
      shift || true
      run_codex resume --last --all "$@"
      ;;
    resume|"")
      shift || true
      run_codex resume --last "$@"
      ;;
    --)
      shift
      run_codex "$@"
      ;;
    *)
      run_codex "$@"
      ;;
  esac
}

add_account() {
  local id="${1:-}" profile
  [ -n "$id" ] || { echo "Usage: codexpm add <profile> [profile_dir]" >&2; exit 1; }
  profile="${2:-$HOME/.codex-$id}"
  codexpm_create_profile "$id" "$profile" 0
  if ! codexpm_add_account_to_config "$id" "$profile"; then
    rm -rf -- "${profile:?}"
    exit 1
  fi
  cat <<EOF_ADDED
Added profile '$id' at:
  $profile

Login with:
  codexpm login $id
EOF_ADDED
}

remove_account() {
  local id="${1:-}" delete_files=0 yes=0 profile active replacement confirm
  [ -n "$id" ] || { echo "Usage: codexpm remove <profile> [--delete-files] [--yes]" >&2; exit 1; }
  shift || true

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --delete-files) delete_files=1 ;;
      --yes) yes=1 ;;
      *) echo "Unknown remove option: $1" >&2; exit 1 ;;
    esac
    shift
  done

  codexpm_account_exists "$id" || {
    echo "Unknown profile: $id" >&2
    exit 1
  }

  if [ "$(codexpm_account_count)" -le 1 ]; then
    echo "The last configured profile cannot be removed." >&2
    echo "Use 'codexpm uninstall --purge' to remove the manager completely." >&2
    exit 1
  fi

  profile="$(codexpm_account_path "$id")"
  active="$(codexpm_read_active)"
  replacement="$(codexpm_next_account "$id")"

  if [ "$delete_files" = "1" ]; then
    codexpm_profile_is_managed "$id" "$profile" || {
      echo "Refusing to delete an unverified profile directory: $profile" >&2
      exit 1
    }

    if [ "$yes" != "1" ]; then
      echo "This will remove profile '$id' from rotation and permanently delete:"
      echo "  $profile"
      echo "Shared sessions and history in $CODEX_ORIGINAL_HOME will not be deleted."
      echo
      read -r -p "Type the profile name '$id' to confirm: " confirm
      [ "$confirm" = "$id" ] || { echo "Cancelled."; exit 0; }
    fi
  fi

  codexpm_remove_account_from_config "$id"

  if [ "$active" = "$id" ]; then
    codexpm_set_active "$replacement"
    echo "Active profile changed: $id -> $replacement"
  fi

  if [ "$delete_files" = "1" ]; then
    if codexpm_delete_profile "$id" "$profile"; then
      echo "Removed profile '$id' and deleted its local files."
    else
      echo "Profile '$id' was removed from rotation, but its files were preserved at:" >&2
      echo "  $profile" >&2
      exit 1
    fi
  else
    cat <<EOF_REMOVED
Removed profile '$id' from rotation.
Its local files were preserved at:
  $profile
EOF_REMOVED
  fi
}

login_account() {
  local id="${1:-}" profile
  [ -n "$id" ] || { echo "Usage: codexpm login <profile>" >&2; exit 1; }
  profile="$(codexpm_account_path "$id")" || { echo "Unknown profile: $id" >&2; exit 1; }
  require_codex
  mkdir -p "$profile"
  chmod 700 "$profile"
  CODEX_HOME="$profile" "$CODEX_BIN" login --device-auth
}

logout_account() {
  local id="${1:-}" profile
  [ -n "$id" ] || { echo "Usage: codexpm logout <profile>" >&2; exit 1; }
  profile="$(codexpm_account_path "$id")" || { echo "Unknown profile: $id" >&2; exit 1; }
  require_codex
  CODEX_HOME="$profile" "$CODEX_BIN" logout
}

doctor() {
  local failed=0 warnings=0 id path item name expected actual mode hash previous linked
  declare -A auth_hashes=()

  echo "Config: $CODEXPM_CONFIG_FILE"
  echo "Codex binary: $CODEX_BIN"
  echo "Original home: $CODEX_ORIGINAL_HOME"
  echo "Lock file: $CODEX_LOCK_FILE"
  echo

  [ -x "$CODEX_BIN" ] || { echo "FAIL: Codex binary is not executable"; failed=1; }
  [ -d "$CODEX_ORIGINAL_HOME" ] || { echo "FAIL: Original Codex home is missing"; failed=1; }

  while IFS= read -r id; do
    path="$(codexpm_account_path "$id")"
    if [ ! -d "$path" ]; then
      echo "FAIL: Profile $id is missing: $path"
      failed=1
      continue
    fi

    echo "OK: Profile $id exists: $path"
    if ! codexpm_profile_is_managed "$id" "$path"; then
      echo "FAIL: Profile $id is missing a valid manager marker"
      failed=1
    fi

    mode="$(stat -c '%a' "$path" 2>/dev/null || true)"
    if [ "$mode" != "700" ]; then
      echo "WARN: Profile $id permissions are $mode, expected 700"
      warnings=$((warnings + 1))
    fi

    if [ -L "$path/auth.json" ]; then
      echo "FAIL: Profile $id auth.json must not be a symlink"
      failed=1
    elif [ -f "$path/auth.json" ]; then
      echo "OK: Profile $id has auth.json"
      mode="$(stat -c '%a' "$path/auth.json" 2>/dev/null || true)"
      case "$mode" in
        600|400) ;;
        *) echo "WARN: Profile $id auth.json permissions are $mode, expected 600"; warnings=$((warnings + 1)) ;;
      esac

      if command -v sha256sum >/dev/null 2>&1; then
        hash="$(sha256sum "$path/auth.json" | awk '{print $1}')"
        previous="${auth_hashes[$hash]:-}"
        if [ -n "$previous" ]; then
          echo "WARN: Profiles $previous and $id have identical auth.json content"
          warnings=$((warnings + 1))
        else
          auth_hashes[$hash]="$id"
        fi
      fi
    else
      echo "INFO: Profile $id is not logged in"
    fi

    while IFS= read -r item; do
      name="$(basename "$item")"
      linked="$path/$name"
      if [ ! -L "$linked" ]; then
        echo "FAIL: Missing shared link for profile $id: $name"
        failed=1
        continue
      fi
      expected="$(readlink -f "$item")"
      actual="$(readlink -f "$linked" 2>/dev/null || true)"
      if [ "$actual" != "$expected" ]; then
        echo "FAIL: Shared link for profile $id points to the wrong target: $name"
        failed=1
      fi
    done < <(codexpm_shared_candidates)

    for linked in "$path"/* "$path"/.[!.]*; do
      [ -L "$linked" ] || continue
      name="$(basename "$linked")"
      [ "$name" != "auth.json" ] || continue
      if ! codexpm_is_shared_name "$name"; then
        actual="$(readlink -f "$linked" 2>/dev/null || true)"
        case "$actual" in
          "$CODEX_ORIGINAL_HOME"/*)
            echo "FAIL: Unexpected shared link in profile $id: $name"
            failed=1
            ;;
        esac
      fi
    done
  done < <(codexpm_account_ids)

  if [ "$failed" -eq 0 ]; then
    if [ "$warnings" -eq 0 ]; then
      echo "Doctor completed successfully."
    else
      echo "Doctor completed with $warnings warning(s)."
    fi
  else
    echo "Doctor found problems." >&2
  fi
  return "$failed"
}

migrate() {
  local id path target
  if [ "$CODEXPM_USING_LEGACY_CONFIG" = "1" ]; then
    echo "Migrating legacy configuration."
  fi
  target="$(codexpm_config_write_target)"
  codexpm_write_config "$target"

  while IFS= read -r id; do
    path="$(codexpm_account_path "$id")"
    codexpm_migrate_profile_links "$path" "$id"
  done < <(codexpm_account_ids)

  echo "Migration complete: $target"
}

uninstall_manager() {
  local script="$BIN_DIR/../uninstall.sh"
  [ -f "$script" ] || {
    echo "Uninstall script was not found: $script" >&2
    echo "Run uninstall.sh from the repository checkout instead." >&2
    exit 1
  }
  exec bash "$script" "$@"
}

case "${1:-help}" in
  help|-h|--help) usage ;;
  version|--version|-V) echo "$CODEXPM_NAME $CODEXPM_VERSION" ;;
  list) show_list ;;
  status) show_status ;;
  use)
    [ -n "${2:-}" ] || { echo "Usage: codexpm use <profile>" >&2; exit 1; }
    codexpm_set_active "$2"
    echo "Active Codex profile is now: $2"
    ;;
  next)
    current="$(codexpm_read_active)"
    next="$(codexpm_next_account "$current")"
    codexpm_set_active "$next"
    echo "Switched Codex profile: $current -> $next"
    ;;
  add) shift; add_account "$@" ;;
  remove) shift; remove_account "$@" ;;
  login) shift; login_account "$@" ;;
  logout) shift; logout_account "$@" ;;
  run) shift; run_command "$@" ;;
  doctor) doctor ;;
  migrate) migrate ;;
  uninstall) shift; uninstall_manager "$@" ;;
  config-path) echo "$CODEXPM_CONFIG_FILE" ;;
  *) echo "Unknown command: $1" >&2; usage >&2; exit 1 ;;
esac
