#!/usr/bin/env bash
set -euo pipefail

CONFIG_FILE="${CODEX2KEYS_CONFIG:-$HOME/.codex2keys.env}"

if [ -f "$CONFIG_FILE" ]; then
  # shellcheck disable=SC1090
  source "$CONFIG_FILE"
fi

CODEX_BIN="${CODEX_BIN:-$HOME/.local/bin/codex}"
CODEX_ACTIVE_FILE="${CODEX_ACTIVE_FILE:-$HOME/.codex-active}"
CODEX_LOCK_FILE="${CODEX_LOCK_FILE:-/tmp/codex-shared-state.lock}"

# Preferred N-account format:
#   CODEX_ACCOUNTS="1:/home/me/.codex-1 2:/home/me/.codex-2 3:/home/me/.codex-3"
# Legacy two-account fallback:
#   CODEX_PROFILE_1 and CODEX_PROFILE_2
CODEX_ACCOUNTS="${CODEX_ACCOUNTS:-}"
if [ -z "$CODEX_ACCOUNTS" ]; then
  CODEX_PROFILE_1="${CODEX_PROFILE_1:-$HOME/.codex-1}"
  CODEX_PROFILE_2="${CODEX_PROFILE_2:-$HOME/.codex-2}"
  CODEX_ACCOUNTS="1:$CODEX_PROFILE_1 2:$CODEX_PROFILE_2"
fi

account_ids() {
  local entry
  for entry in $CODEX_ACCOUNTS; do
    echo "${entry%%:*}"
  done
}

account_path() {
  local wanted="$1"
  local entry id path
  for entry in $CODEX_ACCOUNTS; do
    id="${entry%%:*}"
    path="${entry#*:}"
    if [ "$id" = "$wanted" ]; then
      echo "$path"
      return 0
    fi
  done
  return 1
}

first_account() {
  account_ids | head -n 1
}

is_known_account() {
  account_path "$1" >/dev/null 2>&1
}

read_active() {
  local active
  active="$(cat "$CODEX_ACTIVE_FILE" 2>/dev/null || true)"
  if ! is_known_account "$active"; then
    active="$(first_account)"
  fi
  echo "$active"
}

set_active() {
  local choice="$1"
  if ! is_known_account "$choice"; then
    echo "Invalid account: $choice" >&2
    echo "Known accounts: $(account_ids | xargs)" >&2
    exit 1
  fi

  echo "$choice" > "$CODEX_ACTIVE_FILE"
  chmod 600 "$CODEX_ACTIVE_FILE"
}

next_account() {
  local active="$1"
  local first=""
  local previous=""
  local id

  while read -r id; do
    [ -n "$id" ] || continue
    if [ -z "$first" ]; then
      first="$id"
    fi
    if [ "$previous" = "$active" ]; then
      echo "$id"
      return 0
    fi
    previous="$id"
  done < <(account_ids)

  echo "$first"
}

show_status() {
  local active id path marker
  active="$(read_active)"
  echo "Active Codex account: $active"
  echo

  while read -r id; do
    [ -n "$id" ] || continue
    path="$(account_path "$id")"
    marker=" "
    if [ "$id" = "$active" ]; then
      marker="*"
    fi

    echo "Account $id $marker"
    echo "CODEX_HOME=$path"
    CODEX_HOME="$path" "$CODEX_BIN" login status || true
    echo
  done < <(account_ids)
}

run_codex() {
  local active="$1"
  shift

  local home
  home="$(account_path "$active")"

  if [ ! -x "$CODEX_BIN" ]; then
    echo "CODEX_BIN is not executable: $CODEX_BIN" >&2
    exit 1
  fi

  if [ ! -d "$home" ]; then
    echo "Missing CODEX_HOME for account $active: $home" >&2
    exit 1
  fi

  echo
  echo "Using Codex account: $active"
  echo

  CODEX_HOME="$home" flock -n "$CODEX_LOCK_FILE" "$CODEX_BIN" "$@"
}

case "${1:-}" in
  status)
    show_status
    exit 0
    ;;

  switch)
    shift || true
    codex_switch "$@"
    exit 0
    ;;

  --version|-V|version|--help|-h|help|login|logout)
    active="$(read_active)"
    CODEX_HOME="$(account_path "$active")" "$CODEX_BIN" "$@"
    exit $?
    ;;

  *)
    if [ "$#" -gt 0 ] && is_known_account "$1"; then
      codex_switch "$1"
      exit 0
    fi
    ;;
esac

active="$(read_active)"

case "${1:-resume}" in
  new)
    shift || true
    cmd=("$@")
    ;;

  all)
    shift || true
    cmd=(resume --last --all "$@")
    ;;

  resume|"")
    shift || true
    cmd=(resume --last "$@")
    ;;

  *)
    cmd=("$@")
    ;;
esac

set +e
run_codex "$active" "${cmd[@]}"
status=$?
set -e

echo
echo "Codex ended."
echo "Exit status: $status"
echo "Active account was: $active"
echo

if [ ! -t 0 ]; then
  exit "$status"
fi

other="$(next_account "$active")"
read -r -p "Switch to account $other and resume? [y/N] " answer

case "$answer" in
  y|Y|yes|YES|s|S)
    set_active "$other"
    echo
    echo "Switched Codex account: $active -> $other"
    echo "Resuming with account $other..."
    echo

    set +e
    run_codex "$other" resume --last
    status2=$?
    set -e

    exit "$status2"
    ;;

  *)
    echo "Keeping active Codex account: $active"
    exit "$status"
    ;;
esac
